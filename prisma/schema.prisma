generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  EMPLOYEE
}

model User {
  id         String       @id @default(uuid()) @db.Uuid
  name       String
  username   String       @unique
  password   String
  role       Role         @default(EMPLOYEE)
  isActive   Boolean      @default(true) @map("is_active")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  permissions Permission[]
  createdSheets GoogleSheet[] @relation("CreatedBy")
  updatedSheets GoogleSheet[] @relation("UpdatedBy")
  deletedSheets GoogleSheet[] @relation("DeletedBy")
  clientsCreated  Client[]    @relation("ClientCreatedBy")
  clientsAssigned Client[]    @relation("ClientAssignedTo")
  clientNotes         ClientNote[] @relation("NoteAuthor")
  emergencyNotes      EmergencyNote[] @relation("EmergencyNoteAuthor")
  emergencyNotesDone  EmergencyNote[] @relation("EmergencyNoteDoneBy")
  callLogs            CallLog[]

  @@map("users")
}

model Permission {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  navKey     String   @map("nav_key")
  canAccess  Boolean  @default(false) @map("can_access")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, navKey])
  @@map("permissions")
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model GoogleSheet {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  spreadsheetId String   @unique @map("spreadsheet_id")
  rowCount      Int      @default(10) @map("row_count")
  colCount      Int      @default(10) @map("col_count")
  createdBy     String   @map("created_by") @db.Uuid
  updatedBy     String?  @map("updated_by") @db.Uuid
  deletedBy     String?  @map("deleted_by") @db.Uuid
  isDeleted     Boolean  @default(false) @map("is_deleted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  creator       User      @relation("CreatedBy", fields: [createdBy], references: [id])
  updater       User?     @relation("UpdatedBy", fields: [updatedBy], references: [id])
  deleter       User?     @relation("DeletedBy", fields: [deletedBy], references: [id])
  cells         SheetCell[]

  @@map("google_sheets")
}

model SheetCell {
  id        String  @id @default(uuid()) @db.Uuid
  sheetId   String  @map("sheet_id") @db.Uuid
  row       Int
  col       Int
  value     String? @db.Text
  bold      Boolean @default(false)
  italic    Boolean @default(false)
  fillColor String? @map("fill_color")
  textColor String? @map("text_color")
  align     String  @default("left")
  wrap      Boolean @default(false)
  format    String  @default("text")

  sheet     GoogleSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, row, col])
  @@map("sheet_cells")
}
model Client {
  id                String        @id @default(uuid()) @db.Uuid
  name              String
  shopName          String?       @map("shop_name")
  address           String?       @db.Text
  phone             String
  alternativePhone  String?       @map("alternative_phone")
  email             String?
  businessType      String?       @map("business_type")
  district          String?
  area              String?
  status            ClientStatus  @default(PROSPECT)
  priority          Priority      @default(MEDIUM)
  source            String?       // e.g. "Survey", "Referral", "Walk-in"
  tags              String[]      @default([])
  notes             String?       @db.Text
  rating            Int           @default(0)
  facebookUrl       String?       @map("facebook_url")

  marketId          String?       @map("market_id") @db.Uuid
  market            Market?       @relation(fields: [marketId], references: [id])

  createdById       String        @map("created_by") @db.Uuid
  assignedToId      String?       @map("assigned_to") @db.Uuid
  lastFollowUpAt    DateTime?     @map("last_follow_up_at")
  nextFollowUpAt    DateTime?     @map("next_follow_up_at")
  convertedAt       DateTime?     @map("converted_at")

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  createdBy         User          @relation("ClientCreatedBy", fields: [createdById], references: [id])
  assignedTo        User?         @relation("ClientAssignedTo", fields: [assignedToId], references: [id])
  clientNotes       ClientNote[]
  emergencyNotes    EmergencyNote[]
  callLogs          CallLog[]

  @@index([phone])
  @@index([status])
  @@index([createdById])
  @@index([district])
  @@map("clients")
}

model Market {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  clients   Client[]

  @@map("markets")
}

model EmergencyNote {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  content   String   @db.Text
  priority  Priority @default(MEDIUM)
  isDone    Boolean  @default(false) @map("is_done")
  doneById  String?  @map("done_by") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author    User     @relation("EmergencyNoteAuthor", fields: [authorId], references: [id])
  doneBy    User?    @relation("EmergencyNoteDoneBy", fields: [doneById], references: [id])

  @@index([clientId])
  @@index([authorId])
  @@map("emergency_notes")
}


model ClientNote {
  id          String      @id @default(uuid()) @db.Uuid
  clientId    String      @map("client_id") @db.Uuid
  authorId    String      @map("author_id") @db.Uuid
  content     String      @db.Text
  type        NoteType    @default(GENERAL)
  createdAt   DateTime    @default(now()) @map("created_at")

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author      User        @relation("NoteAuthor", fields: [authorId], references: [id])

  @@index([clientId])
  @@map("client_notes")
}

enum ClientStatus {
  PROSPECT
  CONTACTED
  INTERESTED
  NEGOTIATING
  CLIENTS
  LOST
  INACTIVE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum NoteType {
  GENERAL
  CALL
  VISIT
  FOLLOW_UP
  COMPLAINT
  SMS
}

model CallLog {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  authorId    String   @map("author_id") @db.Uuid
  phoneNumber String   @map("phone_number")
  duration    Int      @default(0) // in seconds
  note        String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id])

  @@index([clientId])
  @@index([authorId])
  @@map("call_logs")
}
